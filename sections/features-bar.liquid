<section class="features-section" data-section-id="{{ section.id }}">
  <div class="section-container">
    <div class="features-grid">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="feature-item" {{ block.shopify_attributes }}>
            <div class="feature-icon">
              {% case block.settings.icon %}
                {% when 'shield' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    <path d="M9 12l2 2 4-4"/>
                  </svg>
                {% when 'gift' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="8" width="18" height="4" rx="1"/>
                    <path d="M12 8v13"/>
                    <path d="M19 12v7a2 2 0 01-2 2H7a2 2 0 01-2-2v-7"/>
                    <path d="M7.5 8a2.5 2.5 0 010-5C9 3 12 8 12 8s3-5 4.5-5a2.5 2.5 0 010 5"/>
                  </svg>
                {% when 'globe' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <path d="M2 12h20"/>
                    <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                  </svg>
                {% when 'heart' %}
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/>
                  </svg>
              {% endcase %}
            </div>
            <h3 class="feature-title">{{ block.settings.title }}</h3>
            <p class="feature-desc">{{ block.settings.description }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .features-section {
    padding: 64px 0;
    background-color: #2B2118;
  }
  .section-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }
  .feature-item {
    text-align: center;
    padding: 24px 16px;
  }
  .feature-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 1px solid rgba(184, 115, 51, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 20px;
    color: #B87333;
    transition: all 0.3s ease;
  }
  .feature-item:hover .feature-icon {
    background-color: rgba(184, 115, 51, 0.1);
    border-color: #B87333;
  }
  .feature-icon svg {
    width: 28px;
    height: 28px;
  }
  .feature-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 20px;
    font-weight: 500;
    color: #F9F6F2;
    margin: 0 0 8px;
  }
  .feature-desc {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: #8C7E6F;
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }
  @media (max-width: 480px) {
    .features-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
    .section-container {
      padding: 0 20px;
    }
    .features-section {
      padding: 48px 0;
    }
  }
</style>

{% schema %}
{
  "name": "Features Bar",
  "tag": "section",
  "class": "features-section",
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "shield", "label": "Shield" },
            { "value": "gift", "label": "Gift" },
            { "value": "globe", "label": "Globe" },
            { "value": "heart", "label": "Heart" }
          ],
          "default": "shield"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Secure Payment"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Your transactions are protected with industry-standard encryption."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Bar",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "shield",
            "title": "Secure Payment",
            "description": "Industry-standard encryption protects every transaction."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "gift",
            "title": "Gift Wrapping",
            "description": "Complimentary artisan gift wrapping on all orders."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "globe",
            "title": "Worldwide Shipping",
            "description": "Free international shipping on orders over ¥599."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "heart",
            "title": "Handcrafted",
            "description": "Every piece is made by hand with love and care."
          }
        }
      ]
    }
  ]
}
{% endschema %}
