<div class="announcement-bar" id="announcement-bar" data-section-id="{{ section.id }}" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="announcement-bar__inner">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="announcement-bar__link">
        {{ section.settings.text }}
      </a>
    {% else %}
      <span class="announcement-bar__text">{{ section.settings.text }}</span>
    {% endif %}
    <button type="button" class="announcement-bar__close" aria-label="Close announcement" onclick="closeAnnouncement()">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M13 1L1 13M1 1L13 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    var bar = document.getElementById('announcement-bar');
    if (!bar) return;
    var sectionId = bar.getAttribute('data-section-id');
    var storageKey = 'announcement-dismissed-' + sectionId;
    if (sessionStorage.getItem(storageKey)) {
      bar.style.display = 'none';
    }
    window.closeAnnouncement = function() {
      sessionStorage.setItem(storageKey, 'true');
      bar.style.display = 'none';
      document.documentElement.style.setProperty('--announcement-height', '0px');
    };
  })();
</script>

<style>
  .announcement-bar {
    width: 100%;
    text-align: center;
    position: relative;
    z-index: 1001;
    transition: all 0.3s ease;
  }
  .announcement-bar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px 40px;
    max-width: 100%;
    position: relative;
  }
  .announcement-bar__link {
    color: inherit;
    text-decoration: none;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }
  .announcement-bar__link:hover {
    opacity: 0.8;
  }
  .announcement-bar__text {
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }
  .announcement-bar__close {
    position: absolute;
    right: 16px;
    top: 50%;
    transform: translateY(-50%);
    background: none;
    border: none;
    cursor: pointer;
    color: inherit;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  .announcement-bar__close:hover {
    opacity: 1;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "announcement-bar-section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Announcement text",
      "default": "Free shipping on orders over ¥599 | Handcrafted with love"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Announcement link"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#2B2118"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#F9F6F2"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar"
    }
  ]
}
{% endschema %}
