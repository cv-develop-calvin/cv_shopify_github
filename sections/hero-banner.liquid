<section class="hero" data-section-id="{{ section.id }}">
  {% if section.settings.background_image != blank %}
    <div class="hero-bg" style="background-image: url('{{ section.settings.background_image | image_url: width: 1920 }}');">
    </div>
  {% else %}
    <div class="hero-bg" style="background-image: url('{{ 'hero-banner.jpg' | asset_url }}');">
    </div>
  {% endif %}
  <div class="hero-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 | round: 2 }};"></div>
  <div class="hero-content">
    <div class="hero-text">
      {% if section.settings.heading != blank %}
        <h1 class="hero-title">{{ section.settings.heading }}</h1>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="hero-desc">{{ section.settings.subheading }}</p>
      {% endif %}
      {% if section.settings.cta_text != blank or section.settings.secondary_cta_text != blank %}
        <div class="hero-buttons">
          {% if section.settings.cta_text != blank %}
            <a href="{{ section.settings.cta_link | default: '#' }}" class="btn btn-primary">
              {{ section.settings.cta_text }}
              {% render 'icon-svg', name: 'arrow-right' %}
            </a>
          {% endif %}
          {% if section.settings.secondary_cta_text != blank %}
            <a href="{{ section.settings.secondary_cta_link | default: '#' }}" class="btn btn-outline">
              {{ section.settings.secondary_cta_text }}
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    {% case section.settings.height %}
      {% when 'small' %}min-height: 50vh;
      {% when 'medium' %}min-height: 65vh;
      {% when 'large' %}min-height: 80vh;
      {% when 'full' %}min-height: 100vh;
      {% else %}min-height: 80vh;
    {% endcase %}
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }
  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(43, 33, 24, 0.85) 0%, rgba(46, 90, 76, 0.6) 100%);
    transition: opacity 0.3s ease;
  }
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 800px;
    padding: 60px 40px;
    text-align: center;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .hero-label {
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #B87333;
    margin-bottom: 8px;
  }
  .hero-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 56px;
    font-weight: 300;
    line-height: 1.15;
    color: #F9F6F2;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .hero-desc {
    font-family: 'Jost', sans-serif;
    font-size: 16px;
    font-weight: 300;
    line-height: 1.7;
    color: #D9CFC4;
    margin: 0;
    max-width: 560px;
  }
  .hero-buttons {
    display: flex;
    gap: 16px;
    margin-top: 12px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Jost', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 16px 36px;
    border-radius: 0;
    cursor: pointer;
    transition: all 0.3s ease;
    border: 1px solid transparent;
  }
  .btn svg {
    width: 16px;
    height: 16px;
    transition: transform 0.3s ease;
  }
  .btn-primary {
    background-color: #B87333;
    color: #F9F6F2;
    border-color: #B87333;
  }
  .btn-primary:hover {
    background-color: #a0642a;
    border-color: #a0642a;
  }
  .btn-primary:hover svg {
    transform: translateX(3px);
  }
  .btn-outline {
    background-color: transparent;
    color: #F9F6F2;
    border-color: rgba(249, 246, 242, 0.4);
  }
  .btn-outline:hover {
    background-color: rgba(249, 246, 242, 0.08);
    border-color: #F9F6F2;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: 70vh !important;
    }
    .hero-content {
      padding: 40px 24px;
    }
    .hero-title {
      font-size: 36px;
    }
    .hero-desc {
      font-size: 14px;
    }
    .hero-buttons {
      flex-direction: column;
      align-items: center;
      width: 100%;
    }
    .btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "hero-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Where Ancient Craft Meets Modern Style"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our handcrafted artisan jewelry collection, where every piece tells a story of heritage and elegance."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Primary CTA text",
      "default": "Explore Collections"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Primary CTA link"
    },
    {
      "type": "text",
      "id": "secondary_cta_text",
      "label": "Secondary CTA text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_cta_link",
      "label": "Secondary CTA link"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 70
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full screen" }
      ],
      "default": "large"
    }
  ],
  "presets": [
    {
      "name": "Hero Banner"
    }
  ]
}
{% endschema %}
