<section class="featured-products-section" data-section-id="{{ section.id }}">
  <div class="section-container">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="section-header">
        {% if section.settings.heading != blank %}
          <h2 class="section-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="section-subtitle">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="products-grid products-grid--cols-{{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        {% if block.type == 'product' %}
          {% assign product = block.settings.product %}
          {% if product != blank %}
            <div class="product-card" {{ block.shopify_attributes }}>
              {% render 'product-card', product: product %}
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .featured-products-section {
    padding: 80px 0;
    background-color: #F9F6F2;
  }
  .section-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }
  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 40px;
    font-weight: 400;
    color: #2B2118;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .section-subtitle {
    font-family: 'Jost', sans-serif;
    font-size: 15px;
    font-weight: 300;
    color: #8C7E6F;
    margin: 0;
    line-height: 1.6;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
  }
  .products-grid {
    display: grid;
    gap: 24px;
  }
  .products-grid--cols-2 {
    grid-template-columns: repeat(2, 1fr);
  }
  .products-grid--cols-3 {
    grid-template-columns: repeat(3, 1fr);
  }
  .products-grid--cols-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  .product-card {
    position: relative;
  }
  .product-card a {
    text-decoration: none;
    display: block;
  }
  .product-image {
    position: relative;
    overflow: hidden;
    background-color: #D9CFC4;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    margin-bottom: 16px;
  }
  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .product-card:hover .product-image img {
    transform: scale(1.04);
  }
  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    z-index: 2;
  }
  .product-badge--new {
    background-color: #2E5A4C;
    color: #F9F6F2;
  }
  .product-badge--sale {
    background-color: #B87333;
    color: #F9F6F2;
  }
  .product-badge--hot {
    background-color: #2B2118;
    color: #F9F6F2;
  }
  .product-wishlist {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background: rgba(249, 246, 242, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.2s ease;
    color: #8C7E6F;
  }
  .product-wishlist:hover {
    background: #F9F6F2;
    color: #B87333;
  }
  .product-wishlist svg {
    width: 18px;
    height: 18px;
  }
  .product-wishlist.is-active {
    color: #B87333;
  }
  .product-wishlist.is-active svg {
    fill: #B87333;
  }
  .product-info {
    text-align: left;
  }
  .product-title {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2B2118;
    margin: 0 0 6px;
    letter-spacing: 0.02em;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .product-price {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    color: #2B2118;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .product-price__current {
    font-weight: 500;
  }
  .product-price__compare {
    font-weight: 300;
    color: #8C7E6F;
    text-decoration: line-through;
    font-size: 13px;
  }

  @media (max-width: 1024px) {
    .products-grid--cols-4 {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media (max-width: 768px) {
    .products-grid--cols-3,
    .products-grid--cols-4 {
      grid-template-columns: repeat(2, 1fr);
    }
    .section-container {
      padding: 0 20px;
    }
    .section-title {
      font-size: 30px;
    }
    .featured-products-section {
      padding: 48px 0;
    }
  }
  @media (max-width: 480px) {
    .products-grid--cols-2,
    .products-grid--cols-3,
    .products-grid--cols-4 {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
  }
</style>

<script>
  document.querySelectorAll('.product-wishlist').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      this.classList.toggle('is-active');
    });
  });
</script>

{% schema %}
{
  "name": "Featured Products",
  "tag": "section",
  "class": "featured-products-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "New Arrivals"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Discover our latest handcrafted pieces, fresh from the artisan workshop."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns on desktop",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Products",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
