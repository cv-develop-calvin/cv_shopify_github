{% comment %}
  Product Card Snippet
  Usage: {% render 'product-card', product: product %}
  Required: product (object)
{% endcomment %}

<a href="{{ product.url }}" class="product-card-link">
  <div class="product-card">
    <div class="product-image">
      {% if product.featured_image != blank %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | default: product.title | escape }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {% elsif product.media[0] != blank %}
        <img
          src="{{ product.media[0] | image_url: width: 600 }}"
          alt="{{ product.title | escape }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {% else %}
        <div class="product-image__placeholder">
          {% render 'icon-svg', name: 'globe' %}
        </div>
      {% endif %}

      {% assign badge_text = '' %}
      {% assign badge_class = '' %}
      {% if product.tags contains 'new' %}
        {% assign badge_text = 'New' %}
        {% assign badge_class = 'product-badge--new' %}
      {% elsif product.compare_at_price > product.price %}
        {% assign badge_text = 'Sale' %}
        {% assign badge_class = 'product-badge--sale' %}
      {% elsif product.tags contains 'hot' %}
        {% assign badge_text = 'Hot' %}
        {% assign badge_class = 'product-badge--hot' %}
      {% endif %}

      {% if badge_text != '' %}
        <span class="product-badge {{ badge_class }}">{{ badge_text }}</span>
      {% endif %}

      <button type="button" class="product-wishlist" aria-label="Add to wishlist" onclick="toggleWishlist(event)">
        {% render 'icon-svg', name: 'heart' %}
      </button>
    </div>

    <div class="product-info">
      <h3 class="product-title">{{ product.title | truncate: 50 }}</h3>
      <div class="product-price">
        <span class="product-price__current">{{ product.price | money }}</span>
        {% if product.compare_at_price > product.price %}
          <span class="product-price__compare">{{ product.compare_at_price | money }}</span>
        {% endif %}
      </div>
    </div>
  </div>
</a>

<script>
  function toggleWishlist(event) {
    event.preventDefault();
    event.stopPropagation();
    var btn = event.currentTarget;
    btn.classList.toggle('is-active');
    var svg = btn.querySelector('svg');
    if (btn.classList.contains('is-active')) {
      svg.outerHTML = '{% render "icon-svg", name: "heart-filled" %}';
    } else {
      svg.outerHTML = '{% render "icon-svg", name: "heart" %}';
    }
  }
</script>

<style>
  .product-card-link {
    text-decoration: none;
    display: block;
  }
  .product-card {
    position: relative;
  }
  .product-image {
    position: relative;
    overflow: hidden;
    background-color: #D9CFC4;
    aspect-ratio: 1 / 1;
    border-radius: 4px;
    margin-bottom: 16px;
  }
  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .product-card:hover .product-image img {
    transform: scale(1.04);
  }
  .product-image__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #D9CFC4 0%, #8C7E6F 100%);
  }
  .product-image__placeholder svg {
    width: 40px;
    height: 40px;
    color: #F9F6F2;
    opacity: 0.4;
  }
  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    font-family: 'Jost', sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    z-index: 2;
  }
  .product-badge--new {
    background-color: #2E5A4C;
    color: #F9F6F2;
  }
  .product-badge--sale {
    background-color: #B87333;
    color: #F9F6F2;
  }
  .product-badge--hot {
    background-color: #2B2118;
    color: #F9F6F2;
  }
  .product-wishlist {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 36px;
    height: 36px;
    background: rgba(249, 246, 242, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: all 0.2s ease;
    color: #8C7E6F;
  }
  .product-wishlist:hover {
    background: #F9F6F2;
    color: #B87333;
  }
  .product-wishlist svg {
    width: 18px;
    height: 18px;
  }
  .product-wishlist.is-active {
    color: #B87333;
  }
  .product-info {
    text-align: left;
  }
  .product-title {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: #2B2118;
    margin: 0 0 6px;
    letter-spacing: 0.02em;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .product-price {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    color: #2B2118;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .product-price__current {
    font-weight: 500;
  }
  .product-price__compare {
    font-weight: 300;
    color: #8C7E6F;
    text-decoration: line-through;
    font-size: 13px;
  }
</style>
