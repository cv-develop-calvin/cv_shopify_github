<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="{{ page_description | default: shop.name | escape }}">
  <title>{{ page_title }}{% unless page_title contains shop.name %} &mdash; {{ shop.name }}{% endunless %}</title>

  {{ content_for_header }}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Jost:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400&display=swap" rel="stylesheet">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <style>
    :root {
      --color-primary: #B87333;
      --color-primary-dark: #9A5F2A;
      --color-primary-light: #D4956A;
      --color-secondary: #2E5A4C;
      --color-secondary-dark: #1E3D33;
      --color-secondary-light: #3D7A66;
      --color-background: #F9F6F2;
      --color-background-alt: #F2EDE7;
      --color-text: #2B2118;
      --color-text-light: #5C4F43;
      --color-muted: #8C7E6F;
      --color-border: #D9CFC4;
      --color-white: #FFFFFF;
      --color-black: #1A1410;
      --font-display: 'Cormorant Garamond', 'Georgia', serif;
      --font-body: 'Jost', 'Helvetica Neue', sans-serif;
      --transition-base: 0.3s ease;
      --transition-slow: 0.5s ease;
      --shadow-sm: 0 1px 3px rgba(43, 33, 24, 0.08);
      --shadow-md: 0 4px 12px rgba(43, 33, 24, 0.1);
      --shadow-lg: 0 8px 30px rgba(43, 33, 24, 0.12);
      --shadow-xl: 0 16px 50px rgba(43, 33, 24, 0.15);
      --radius-sm: 4px;
      --radius-md: 8px;
      --radius-lg: 12px;
      --radius-xl: 20px;
      --radius-full: 9999px;
      --container-max: 1280px;
      --container-padding: 24px;
    }
  </style>
</head>

<body>
  <a href="#main-content" class="skip-to-content">
    {{ 'accessibility.skip_to_content' | t }}
  </a>

  {% render 'section-groups', location: 'announcement-bar' %}
  {% render 'section-groups', location: 'header' %}

  <main id="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% render 'section-groups', location: 'footer' %}

  {{ 'theme.js' | asset_url | script_tag }}
</body>
</html>
